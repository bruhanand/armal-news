{
  "name": "armal-news",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @armal/shared db:migrate",
    "db:seed": "pnpm --filter @armal/shared db:seed",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test"
  },
  "engines": {
    "node": ">=20"
  }
}
