{
  "name": "armal-news",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @armal/shared db:migrate",
    "typecheck": "pnpm --filter @armal/shared typecheck",
    "test": "pnpm --filter @armal/shared test"
  },
  "engines": {
    "node": ">=20"
  }
}
