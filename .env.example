# Local Postgres (docker-compose) — read by both apps and drizzle-kit.
DATABASE_URL=postgres://armal:armal@localhost:5432/armal_news

# Supabase project URL (e.g. https://abcd.supabase.co).
# Read by apps/admin (to upload to Storage) AND apps/web (to whitelist
# the Storage CDN host in next.config). Public — safe to commit shape.
SUPABASE_URL=

# Service-role key for the Supabase project. Bypasses RLS and is used
# ONLY by apps/admin to upload to the `story-images` bucket. NEVER add
# this to apps/web's environment.
SUPABASE_SERVICE_ROLE_KEY=
