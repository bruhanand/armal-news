# ──────────────────────────────────────────────────────────────────────
# Drizzle / Supabase
# ──────────────────────────────────────────────────────────────────────
# Generated SQL migrations and metadata are committed under packages/shared/db.
# Local CLI scratch state is not.
supabase/.branches/
supabase/.temp/
supabase/.env

# ──────────────────────────────────────────────────────────────────────
# Tests / coverage
# ──────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
.vitest-cache/

# ──────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────────────────────────────
# Claude Code / agents
# ──────────────────────────────────────────────────────────────────────
# Per-machine settings. The shared `.claude/settings.json` (if added later)
# and the project skills under `.claude/skills/` and `.agents/skills/`
# stay checked in.
.claude/settings.local.json
.claude/launch.json

# ──────────────────────────────────────────────────────────────────────
# Generated audit / review artefacts
# ──────────────────────────────────────────────────────────────────────
